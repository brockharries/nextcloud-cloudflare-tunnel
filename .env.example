# Copy this file to `.env` and fill in real values LOCALLY.
# `.env` is gitignored. Never commit real secrets.

# --- General ---
TZ=Etc/UTC

# --- Nextcloud database (MariaDB) ---
DB_NAME=nextcloud
DB_USER=nextcloud
DB_PASSWORD=<REDACTED-generate-a-strong-password>
DB_ROOT_PASSWORD=<REDACTED-generate-a-different-strong-password>

# --- Cloudflare Tunnel ---
# Issued in the Cloudflare Zero Trust dashboard when you create the tunnel.
# This single token is what lets cloudflared join the tunnel. Treat it like a password.
CLOUDFLARE_TUNNEL_TOKEN=<REDACTED-cloudflare-tunnel-token>

# --- Public hostname (configured in Cloudflare DNS as a CNAME to the tunnel) ---
PUBLIC_HOSTNAME=cloud.your-domain.com
